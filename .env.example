# =========== Database ===========
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=

# =========== Django ===========
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,web
SUPERUSER_USERNAME=
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=

# =========== Ollama / LLM ===========
OLLAMA_URL=http://ollama:11434
LLM_PROVIDER=ollama
# How long Ollama keeps the model loaded in RAM after a request.
# Reloading a multi-GB model from disk takes ~90s+ on CPU, so keep this
# generous unless memory-constrained. "-1" = never unload.
OLLAMA_KEEP_ALIVE=30m

# =========== Embeddings ===========
EMBEDDING_PROVIDER=huggingface

# =========== Optional paid/upgrade keys (leave blank if unused) ===========
HF_TOKEN=
OPENAI_API_KEY=
ESV_API_KEY=
KAGGLE_API_TOKEN=